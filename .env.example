# =============================================================================
# SourceBase Environment Variables (example - DO NOT commit real values)
# =============================================================================
# Copy this to .env and fill in real values.
# .env is gitignored and must never be committed.

# ---------------------------------------------------------------------------
# Flutter / Docker Build Args (passed as --dart-define during build)
# These become embedded in the Flutter web JS bundle.
# ONLY public values here; never put service_role or private keys.
# ---------------------------------------------------------------------------
SOURCEBASE_SUPABASE_URL="https://your-project.supabase.co"
SOURCEBASE_SUPABASE_ANON_KEY="your-supabase-anon-key"
SOURCEBASE_PUBLIC_URL="https://sourcebase.medasi.com.tr"
SOURCEBASE_MOBILE_REDIRECT_URL="sourcebase://auth/callback"
SOURCEBASE_GOOGLE_OAUTH_ENABLED="false"
SOURCEBASE_APPLE_OAUTH_ENABLED="false"

# ---------------------------------------------------------------------------
# Coolify Deployment
# ---------------------------------------------------------------------------
SOURCEBASE_COOLIFY_APP_UUID="sourcebase-coolify-app-uuid"
SOURCEBASE_COOLIFY_API_KEY="your-coolify-api-bearer-token"
SOURCEBASE_COOLIFY_URL="http://your-coolify-server:8000"
SOURCEBASE_DEPLOY_WEBHOOK="https://coolify.example.com/api/v1/deploy?uuid=..."

# ---------------------------------------------------------------------------
# Supabase Server-Side Secrets (Edge Function runtime only)
# NEVER pass these to Flutter/Docker build args.
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ---------------------------------------------------------------------------
# MedAsiPay (Edge Function runtime only)
# These are server-side secrets. Do not pass them as Flutter/Docker build args.
# ---------------------------------------------------------------------------
MEDASIPAY_API_URL="https://odeme.medasi.com.tr"
MEDASIPAY_API_KEY=""
SOURCEBASE_MEDASIPAY_WEBHOOK_SECRET=""
SOURCEBASE_PAYMENT_WEBHOOK_URL="https://medasi.com.tr/functions/v1/sourcebase"

# ---------------------------------------------------------------------------
# S3-compatible storage / MinIO (file upload)
# ---------------------------------------------------------------------------
SOURCEBASE_STORAGE_DRIVER="s3"
SOURCEBASE_S3_ENDPOINT="https://storage.medasi.com.tr"
SOURCEBASE_S3_BUCKET="medasistorage"
SOURCEBASE_S3_REGION="us-east-1"
SOURCEBASE_S3_ACCESS_KEY=""
SOURCEBASE_S3_SECRET_KEY=""
SOURCEBASE_ALLOWED_ORIGIN="https://sourcebase.medasi.com.tr"

# ---------------------------------------------------------------------------
# Vertex AI (AI content generation)
# ---------------------------------------------------------------------------
VERTEX_PROJECT_ID="your-gcp-project-id"
VERTEX_LOCATION="us-central1"
VERTEX_MODEL="gemini-2.5-flash"
VERTEX_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"your-project-id","private_key_id":"your-private-key-id","private_key":"your-private-key-pem","client_email":"your-service-account-email"}'
